{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "meta": {
    "title": "Ambient Backgrounds Demo",
    "description": "A demo of the Ambient Backgrounds plugin — add animated ambient blur backgrounds to any WordPress page.",
    "author": "Tarek Zaher",
    "categories": [
      "plugins"
    ]
  },
  "login": true,
  "landingPage": "/imagine-the-possibilities",
  "preferredVersions": {
    "php": "8.3",
    "wp": "latest"
  },
  "steps": [
    {
      "step": "installPlugin",
      "pluginZipFile": {
        "resource": "url",
        "url": "https://raw.githubusercontent.com/Tarek-Zaher/ambient-backgrounds/main/ambient-backgrounds.zip"
      }
    },
    {
      "step": "runPHPWithOptions",
      "options": {
        "code": "<?php\nrequire_once '/wordpress/wp-load.php';\n$content = getenv('CONTENT');\nremove_all_filters('content_save_pre');\nremove_all_filters('content_filtered_save_pre');\nwp_insert_post([\n\t'post_title'   => 'Imagine the Possibilities',\n\t'post_content' => $content,\n\t'post_status'  => 'publish',\n\t'post_type'    => 'page',\n\t'post_name'    => 'imagine-the-possibilities',\n]);\n",
        "env": {
          "CONTENT": "<!-- wp:ambient-backgrounds/ambient-background {\"align\":\"full\"} -->\n<div style=\"position:relative;overflow:hidden\" data-circle-count=\"150\" data-base-radius=\"100\" data-range-radius=\"200\" data-starting-hue=\"220\" data-range-hue=\"60\" data-background-color=\"hsla(0,0%,5%,1)\" data-cycle-hue=\"false\" data-hue-speed=\"1\" class=\"wp-block-ambient-backgrounds-ambient-background alignfull has-hsla-0-0-5-1-background-color has-background\"><div class=\"ambient-background-canvas\" style=\"position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:0\"></div><div class=\"ambient-background-content\" style=\"position:relative;z-index:1\"><!-- wp:columns {\"verticalAlignment\":\"center\",\"align\":\"wide\"} -->\n<div class=\"wp-block-columns alignwide are-vertically-aligned-center\"><!-- wp:column {\"style\":{\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|70\",\"bottom\":\"var:preset|spacing|70\"}}},\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-column\" style=\"padding-top:var(--wp--preset--spacing--70);padding-bottom:var(--wp--preset--spacing--70)\"><!-- wp:columns -->\n<div class=\"wp-block-columns\"><!-- wp:column {\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-column\"><!-- wp:heading {\"level\":1,\"className\":\"is-style-text-display\",\"style\":{\"typography\":{\"textAlign\":\"center\"}}} -->\n<h1 class=\"wp-block-heading has-text-align-center is-style-text-display\">Imagine the Possibilities</h1>\n<!-- /wp:heading --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns -->\n<!-- wp:paragraph {\"className\":\"is-style-default\",\"style\":{\"typography\":{\"textAlign\":\"center\"},\"spacing\":{\"padding\":{\"right\":\"var:preset|spacing|80\",\"left\":\"var:preset|spacing|80\"},\"margin\":{\"right\":\"var:preset|spacing|80\",\"left\":\"var:preset|spacing|80\"}}}} -->\n<p class=\"has-text-align-center is-style-default\" style=\"margin-right:var(--wp--preset--spacing--80);margin-left:var(--wp--preset--spacing--80);padding-right:var(--wp--preset--spacing--80);padding-left:var(--wp--preset--spacing--80)\">So many WordPress backgrounds are boring and bland. </p>\n<!-- /wp:paragraph -->\n<!-- wp:paragraph {\"className\":\"is-style-default\",\"style\":{\"typography\":{\"textAlign\":\"center\"},\"spacing\":{\"padding\":{\"right\":\"var:preset|spacing|80\",\"left\":\"var:preset|spacing|80\"},\"margin\":{\"right\":\"var:preset|spacing|80\",\"left\":\"var:preset|spacing|80\"}}}} -->\n<p class=\"has-text-align-center is-style-default\" style=\"margin-right:var(--wp--preset--spacing--80);margin-left:var(--wp--preset--spacing--80);padding-right:var(--wp--preset--spacing--80);padding-left:var(--wp--preset--spacing--80)\">But an overstimulating animation distracts from the real goals of your site.</p>\n<!-- /wp:paragraph -->\n<!-- wp:paragraph {\"className\":\"is-style-default\",\"style\":{\"typography\":{\"textAlign\":\"center\"},\"spacing\":{\"padding\":{\"right\":\"var:preset|spacing|80\",\"left\":\"var:preset|spacing|80\"},\"margin\":{\"right\":\"var:preset|spacing|80\",\"left\":\"var:preset|spacing|80\"}}}} -->\n<p class=\"has-text-align-center is-style-default\" style=\"margin-right:var(--wp--preset--spacing--80);margin-left:var(--wp--preset--spacing--80);padding-right:var(--wp--preset--spacing--80);padding-left:var(--wp--preset--spacing--80)\"> Enter Ambient Backgrounds! </p>\n<!-- /wp:paragraph -->\n<!-- wp:paragraph {\"className\":\"is-style-default\",\"style\":{\"typography\":{\"textAlign\":\"center\"},\"spacing\":{\"padding\":{\"right\":\"var:preset|spacing|80\",\"left\":\"var:preset|spacing|80\"},\"margin\":{\"right\":\"var:preset|spacing|80\",\"left\":\"var:preset|spacing|80\"}}}} -->\n<p class=\"has-text-align-center is-style-default\" style=\"margin-right:var(--wp--preset--spacing--80);margin-left:var(--wp--preset--spacing--80);padding-right:var(--wp--preset--spacing--80);padding-left:var(--wp--preset--spacing--80)\">Now you can add a killer background to your WordPress site at the click of a button. You can even customize it to match your brand and taste. </p>\n<!-- /wp:paragraph -->\n<!-- wp:paragraph {\"style\":{\"typography\":{\"textAlign\":\"center\"}}} -->\n<p class=\"has-text-align-center\">Add it like any other block to your site and start transforming your backgrounds into something amazing!</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns --></div></div>\n<!-- /wp:ambient-backgrounds/ambient-background -->"
        }
      }
    }
  ],
  "features": {}
}