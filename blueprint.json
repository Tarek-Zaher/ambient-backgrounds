{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "meta": {
    "title": "Ambient Backgrounds Demo",
    "description": "A demo of the Ambient Backgrounds plugin — add animated ambient blur backgrounds to any WordPress page.",
    "author": "Tarek Zaher",
    "categories": [
      "plugins"
    ]
  },
  "login": true,
  "landingPage": "/imagine-the-possibilities",
  "preferredVersions": {
    "php": "8.3",
    "wp": "latest"
  },
  "steps": [
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "Ambient Backgrounds Demo"
      }
    },
    {
      "step": "installPlugin",
      "pluginZipFile": {
        "resource": "url",
        "url": "https://raw.githubusercontent.com/Tarek-Zaher/ambient-backgrounds/main/ambient-backgrounds.zip"
      }
    },
    {
      "step": "runPHPWithOptions",
      "options": {
        "code": "<?php\nrequire_once '/wordpress/wp-load.php';\n$content = getenv('CONTENT');\nremove_all_filters('content_save_pre');\nremove_all_filters('content_filtered_save_pre');\n$post_id = wp_insert_post([\n\t'post_title'   => 'Imagine the Possibilities',\n\t'post_content' => $content,\n\t'post_status'  => 'publish',\n\t'post_type'    => 'page',\n\t'post_name'    => 'imagine-the-possibilities',\n]);\n// Hide the page title via post meta (works with most themes)\nupdate_post_meta($post_id, 'hide_title', true);\nupdate_post_meta($post_id, '_hide_post_title', true);\nupdate_post_meta($post_id, 'ast-featured-img', 'disabled');\n",
        "env": {
          "CONTENT": "<!-- wp:ambient-backgrounds/ambient-background {\"align\":\"full\"} -->\n<div class=\"wp-block-ambient-backgrounds-ambient-background alignfull\" style=\"position:relative;overflow:hidden\" data-background-type=\"blur\" data-background-color=\"hsla(0,0%,5%,1)\" data-circle-count=\"150\" data-base-radius=\"100\" data-range-radius=\"200\" data-starting-hue=\"220\" data-range-hue=\"60\" data-cycle-hue=\"false\" data-hue-speed=\"1\" data-star-count=\"5000\" data-speed-factor=\"0.05\" data-star-color=\"#ffffff\" data-warp-on-press=\"true\" data-warp-speed-factor=\"0.2\"><div class=\"ambient-background-canvas\" style=\"position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:0\"></div><div class=\"ambient-background-content\" style=\"position:relative;z-index:1\"><!-- wp:heading {\"level\":1,\"className\":\"is-style-text-display\",\"style\":{\"typography\":{\"textAlign\":\"center\"},\"spacing\":{\"padding\":{\"top\":\"10rem\",\"bottom\":\"10rem\"}}}} -->\n<h1 class=\"wp-block-heading has-text-align-center is-style-text-display\" style=\"padding-top:10rem;padding-bottom:10rem\">Blur</h1>\n<!-- /wp:heading --></div></div>\n<!-- /wp:ambient-backgrounds/ambient-background -->\n\n<!-- wp:ambient-backgrounds/ambient-background {\"backgroundType\":\"starfield\",\"align\":\"full\"} -->\n<div class=\"wp-block-ambient-backgrounds-ambient-background alignfull\" style=\"position:relative;overflow:hidden\" data-background-type=\"starfield\" data-background-color=\"hsla(0,0%,5%,1)\" data-circle-count=\"150\" data-base-radius=\"100\" data-range-radius=\"200\" data-starting-hue=\"220\" data-range-hue=\"60\" data-cycle-hue=\"false\" data-hue-speed=\"1\" data-star-count=\"5000\" data-speed-factor=\"0.05\" data-star-color=\"#ffffff\" data-warp-on-press=\"true\" data-warp-speed-factor=\"0.2\"><div class=\"ambient-background-canvas\" style=\"position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:0\"></div><div class=\"ambient-background-content\" style=\"position:relative;z-index:1\"><!-- wp:heading {\"level\":1,\"className\":\"is-style-text-display\",\"style\":{\"typography\":{\"textAlign\":\"center\"},\"spacing\":{\"padding\":{\"top\":\"10rem\",\"bottom\":\"10rem\"}}}} -->\n<h1 class=\"wp-block-heading has-text-align-center is-style-text-display\" style=\"padding-top:10rem;padding-bottom:10rem\">StarField</h1>\n<!-- /wp:heading --></div></div>\n<!-- /wp:ambient-backgrounds/ambient-background -->\n<!-- wp:html -->\n<style>\n#wp-block-post-title,\n.wp-block-post-title { display: none; }\n</style>\n<!-- /wp:html -->"
        }
      }
    }
  ],
  "features": {}
}